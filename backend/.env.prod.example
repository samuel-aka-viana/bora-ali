APP_ENV=prod
PUBLIC_BASE_URL=https://your-production-domain.com

DJANGO_SECRET_KEY=replace-with-a-strong-random-secret-key-at-least-50-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-production-domain.com,www.your-production-domain.com
CORS_ALLOWED_ORIGINS=https://your-production-domain.com
CSRF_TRUSTED_ORIGINS=https://your-production-domain.com

POSTGRES_DB=bora_ali
POSTGRES_USER=bora
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

USE_VERSITYGW=True
AWS_STORAGE_BUCKET_NAME=bora-ali
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=https://your-s3-endpoint.example.com
AWS_S3_PUBLIC_URL=https://your-production-domain.com/bora-ali
AWS_S3_PUBLIC_ENDPOINT=https://your-production-domain.com
AWS_S3_URL_EXPIRES_IN=3600
AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key

GOOGLE_OAUTH_CLIENT_ID=
