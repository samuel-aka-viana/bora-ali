# ============================================================
# Variáveis obrigatórias — copie para .env e preencha antes de rodar
# NUNCA commite o .env real no Git
# ============================================================

# Django
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
APP_ENV=prod
PUBLIC_BASE_URL=https://seudominio.com
DJANGO_SECRET_KEY=troque-por-chave-forte-gerada-aleatoriamente
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=seudominio.com,www.seudominio.com

# Banco de dados
POSTGRES_DB=bora_ali
POSTGRES_USER=bora
POSTGRES_PASSWORD=troque-por-senha-forte
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS e CSRF (liste apenas origens confiáveis, sem trailing slash)
CORS_ALLOWED_ORIGINS=https://seudominio.com
CSRF_TRUSTED_ORIGINS=https://seudominio.com

# Storage de mídia (VersityGW / S3-compatible)
# Deixe USE_VERSITYGW=False para usar filesystem local em dev
USE_VERSITYGW=False
AWS_STORAGE_BUCKET_NAME=bora-ali
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=http://localhost:8081
AWS_S3_USE_SSL=True
AWS_ACCESS_KEY_ID=troque-por-access-key
AWS_SECRET_ACCESS_KEY=troque-por-secret-key
# URL pública das mídias (domínio do bucket/CDN exposto ao browser)
AWS_S3_PUBLIC_URL=https://seudominio.com/bora-ali

# Google OAuth para login social
GOOGLE_OAUTH_CLIENT_ID=seu-client-id-do-google

# OpenTelemetry — remova ou deixe vazio para desativar tracing
OTEL_SERVICE_NAME=bora-ali
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# VersityGW (apenas para docker-compose local)
VERSITYGW_ACCESS_KEY=troque-por-access-key
VERSITYGW_SECRET_KEY=troque-por-secret-key
